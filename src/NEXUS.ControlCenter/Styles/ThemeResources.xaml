<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="NexusWindowBackgroundColor">#07111A</Color>
            <Color x:Key="NexusSurfaceColor">#0E1A26</Color>
            <Color x:Key="NexusSurfaceRaisedColor">#132434</Color>
            <Color x:Key="NexusPanelColor">#0A1520</Color>
            <Color x:Key="NexusAccentColor">#3AE8D0</Color>
            <Color x:Key="NexusAccentMutedColor">#1A9D90</Color>
            <Color x:Key="NexusWarningColor">#F8C15A</Color>
            <Color x:Key="NexusDangerColor">#FF7B8A</Color>
            <Color x:Key="NexusTextPrimaryColor">#F2F8FC</Color>
            <Color x:Key="NexusTextMutedColor">#96A8B8</Color>
            <Color x:Key="NexusBorderColor">#1E4050</Color>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
            <Color x:Key="NexusWindowBackgroundColor">#F3F7FB</Color>
            <Color x:Key="NexusSurfaceColor">#FFFFFF</Color>
            <Color x:Key="NexusSurfaceRaisedColor">#E9F1F7</Color>
            <Color x:Key="NexusPanelColor">#EDF4FA</Color>
            <Color x:Key="NexusAccentColor">#007F74</Color>
            <Color x:Key="NexusAccentMutedColor">#3C8F87</Color>
            <Color x:Key="NexusWarningColor">#AF7A07</Color>
            <Color x:Key="NexusDangerColor">#C44257</Color>
            <Color x:Key="NexusTextPrimaryColor">#101820</Color>
            <Color x:Key="NexusTextMutedColor">#576B7D</Color>
            <Color x:Key="NexusBorderColor">#C9D8E4</Color>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Default">
            <Color x:Key="NexusWindowBackgroundColor">#07111A</Color>
            <Color x:Key="NexusSurfaceColor">#0E1A26</Color>
            <Color x:Key="NexusSurfaceRaisedColor">#132434</Color>
            <Color x:Key="NexusPanelColor">#0A1520</Color>
            <Color x:Key="NexusAccentColor">#3AE8D0</Color>
            <Color x:Key="NexusAccentMutedColor">#1A9D90</Color>
            <Color x:Key="NexusWarningColor">#F8C15A</Color>
            <Color x:Key="NexusDangerColor">#FF7B8A</Color>
            <Color x:Key="NexusTextPrimaryColor">#F2F8FC</Color>
            <Color x:Key="NexusTextMutedColor">#96A8B8</Color>
            <Color x:Key="NexusBorderColor">#1E4050</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <SolidColorBrush x:Key="NexusWindowBackgroundBrush" Color="{ThemeResource NexusWindowBackgroundColor}" />
    <SolidColorBrush x:Key="NexusSurfaceBrush" Color="{ThemeResource NexusSurfaceColor}" />
    <SolidColorBrush x:Key="NexusSurfaceRaisedBrush" Color="{ThemeResource NexusSurfaceRaisedColor}" />
    <SolidColorBrush x:Key="NexusPanelBrush" Color="{ThemeResource NexusPanelColor}" />
    <SolidColorBrush x:Key="NexusAccentBrush" Color="{ThemeResource NexusAccentColor}" />
    <SolidColorBrush x:Key="NexusAccentMutedBrush" Color="{ThemeResource NexusAccentMutedColor}" />
    <SolidColorBrush x:Key="NexusWarningBrush" Color="{ThemeResource NexusWarningColor}" />
    <SolidColorBrush x:Key="NexusDangerBrush" Color="{ThemeResource NexusDangerColor}" />
    <SolidColorBrush x:Key="NexusTextPrimaryBrush" Color="{ThemeResource NexusTextPrimaryColor}" />
    <SolidColorBrush x:Key="NexusTextMutedBrush" Color="{ThemeResource NexusTextMutedColor}" />
    <SolidColorBrush x:Key="NexusBorderBrush" Color="{ThemeResource NexusBorderColor}" />

    <Thickness x:Key="NexusPagePadding">24</Thickness>
    <CornerRadius x:Key="NexusPanelCornerRadius">16</CornerRadius>

    <Style x:Key="NexusEyebrowTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource NexusAccentBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="120" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="NexusHeroTitleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource NexusTextPrimaryBrush}" />
        <Setter Property="FontSize" Value="34" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="NexusBodyMutedTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource NexusTextMutedBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="NexusCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource NexusSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource NexusBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource NexusPanelCornerRadius}" />
        <Setter Property="Padding" Value="16" />
    </Style>
</ResourceDictionary>
