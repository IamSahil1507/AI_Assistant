<Page
    x:Class="NEXUS.ControlCenter.Pages.BrowserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid Padding="{StaticResource NexusPagePadding}">
        <Border Style="{StaticResource NexusCardBorderStyle}">
            <StackPanel Spacing="16">
                <TextBlock Text="NEXUS / BROWSER" Style="{StaticResource NexusEyebrowTextStyle}" />
                <TextBlock Text="Browser operator handoff" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="This is the first browser parity pass: start an operator task, open a URL, and capture the resulting browser artifact trail." Style="{StaticResource NexusBodyMutedTextStyle}" />

                <muxc:InfoBar x:Name="StatusBar"
                              IsOpen="True"
                              Severity="Informational"
                              Title="Browser runtime"
                              Message="Ready for a URL." />

                <TextBox x:Name="UrlTextBox" PlaceholderText="https://example.com" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Open URL" Click="OpenUrlButton_Click" />
                </StackPanel>

                <TextBlock x:Name="TaskIdText" Style="{StaticResource NexusBodyMutedTextStyle}" />
                <TextBlock x:Name="ResultSummaryText" FontWeight="SemiBold" />
                <TextBlock x:Name="ResultDetailText"
                           TextWrapping="Wrap"
                           Style="{StaticResource NexusBodyMutedTextStyle}" />
                <TextBlock x:Name="ArtifactPathText"
                           TextWrapping="Wrap"
                           Style="{StaticResource NexusBodyMutedTextStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
