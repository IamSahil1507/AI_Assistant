<Page
    x:Class="NEXUS.ControlCenter.Pages.FeaturePlaceholderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid Padding="{StaticResource NexusPagePadding}">
        <Border Style="{StaticResource NexusCardBorderStyle}">
            <StackPanel Spacing="16">
                <TextBlock x:Name="EyebrowText" Style="{StaticResource NexusEyebrowTextStyle}" />
                <TextBlock x:Name="TitleText" Style="{StaticResource NexusHeroTitleTextStyle}" />
                <TextBlock x:Name="DescriptionText" Style="{StaticResource NexusBodyMutedTextStyle}" />
                <muxc:InfoBar IsOpen="True"
                              Severity="Informational"
                              Title="Planned slice"
                              Message="This section is scaffolded in the new shell and ready for feature-specific implementation in the next passes." />
            </StackPanel>
        </Border>
    </Grid>
</Page>
