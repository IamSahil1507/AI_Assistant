<Page
    x:Class="NEXUS.ControlCenter.Pages.ChatsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid Padding="{StaticResource NexusPagePadding}" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource NexusCardBorderStyle}">
            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
                <StackPanel>
                    <TextBlock Text="NEXUS / CHATS" Style="{StaticResource NexusEyebrowTextStyle}" />
                    <TextBlock Text="Session links" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Refresh" Click="RefreshButton_Click" />
                    <Button Content="New chat" Click="NewChatButton_Click" />
                </StackPanel>

                <ListView x:Name="ThreadsList"
                          Grid.Row="2"
                          SelectionChanged="ThreadsList_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    Background="{ThemeResource NexusSurfaceRaisedBrush}"
                                    BorderBrush="{ThemeResource NexusBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Preview}" Style="{StaticResource NexusBodyMutedTextStyle}" />
                                    <TextBlock Text="{Binding UpdatedLabel}" Style="{StaticResource NexusBodyMutedTextStyle}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource NexusCardBorderStyle}">
            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
                <StackPanel>
                    <TextBlock Text="Conversation feed" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="ConversationHintText"
                               Text="Select a session or use the bottom command dock to start a new one."
                               Style="{StaticResource NexusBodyMutedTextStyle}" />
                </StackPanel>

                <muxc:InfoBar x:Name="ErrorBar"
                              Grid.Row="1"
                              IsOpen="False"
                              Severity="Error"
                              Title="Chat error"
                              Message="-" />

                <ListView x:Name="MessagesList" Grid.Row="2">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="12"
                                    Background="{ThemeResource NexusSurfaceRaisedBrush}"
                                    BorderBrush="{ThemeResource NexusBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Role}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding TimestampLabel}" Style="{StaticResource NexusBodyMutedTextStyle}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
