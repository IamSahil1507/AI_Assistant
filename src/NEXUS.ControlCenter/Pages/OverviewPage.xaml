<Page
    x:Class="NEXUS.ControlCenter.Pages.OverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="{StaticResource NexusPagePadding}" Spacing="16">
            <TextBlock Text="NEXUS / OVERVIEW" Style="{StaticResource NexusEyebrowTextStyle}" />
            <TextBlock Text="Mission control is live." Style="{StaticResource NexusHeroTitleTextStyle}" />
            <TextBlock Text="This first foundation pass wires the new shell to the backend, keeps the sci-fi direction, and gives us the frame we can grow into parity." Style="{StaticResource NexusBodyMutedTextStyle}" />

            <muxc:InfoBar x:Name="StatusBar"
                          IsOpen="True"
                          Severity="Informational"
                          Title="Shell status"
                          Message="Initializing…" />

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource NexusCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Connection" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock x:Name="ConnectionStateText" Style="{StaticResource NexusBodyMutedTextStyle}" />
                        <TextBlock x:Name="BackendUrlText" Style="{StaticResource NexusBodyMutedTextStyle}" />
                        <TextBlock x:Name="RefreshedAtText" Style="{StaticResource NexusBodyMutedTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource NexusCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Profile" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock x:Name="ProfileText" Style="{StaticResource NexusBodyMutedTextStyle}" />
                        <TextBlock x:Name="SurfaceText" Style="{StaticResource NexusBodyMutedTextStyle}" />
                        <TextBlock x:Name="OpenBehaviorText" Style="{StaticResource NexusBodyMutedTextStyle}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource NexusCardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Quick actions" FontSize="16" FontWeight="SemiBold" />
                    <ItemsControl x:Name="QuickActionsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,8,8"
                                        Padding="10,6"
                                        Background="{ThemeResource NexusSurfaceRaisedBrush}"
                                        BorderBrush="{ThemeResource NexusBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="999">
                                    <TextBlock Text="{Binding}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource NexusCardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Mission state" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="Policy" Style="{StaticResource NexusEyebrowTextStyle}" />
                    <TextBlock x:Name="PolicySummaryText"
                               TextWrapping="Wrap"
                               Style="{StaticResource NexusBodyMutedTextStyle}" />
                    <TextBlock Text="Memory" Style="{StaticResource NexusEyebrowTextStyle}" />
                    <TextBlock x:Name="MemorySummaryText"
                               TextWrapping="Wrap"
                               Style="{StaticResource NexusBodyMutedTextStyle}" />
                    <TextBlock Text="Gateway" Style="{StaticResource NexusEyebrowTextStyle}" />
                    <TextBlock x:Name="GatewaySummaryText"
                               TextWrapping="Wrap"
                               Style="{StaticResource NexusBodyMutedTextStyle}" />
                </StackPanel>
            </Border>

            <Button Content="Refresh backend state"
                    HorizontalAlignment="Left"
                    Click="RefreshButton_Click" />
        </StackPanel>
    </ScrollViewer>
</Page>
