<Page
    x:Class="Awarenet.ControlCenter.Pages.ModulesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid Padding="16" RowDefinitions="Auto,Auto,*">
        <StackPanel Spacing="4">
            <TextBlock Text="Config / Modules" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="Live capabilities + feature flags. Toggle modules in real time." Opacity="0.8" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,12,0,12">
            <Button x:Name="RefreshButton" Content="Refresh" />
            <TextBlock Text="Backend:" VerticalAlignment="Center" Opacity="0.8" />
            <TextBlock x:Name="BackendUrlText" Text="http://127.0.0.1:8000" VerticalAlignment="Center" />
        </StackPanel>

        <Grid Grid.Row="2" RowDefinitions="Auto,*">
            <muxc:InfoBar x:Name="ErrorBar"
                          Grid.Row="0"
                          IsOpen="False"
                          Severity="Error"
                          Title="Error"
                          Message="-" />

            <ListView x:Name="ModulesList" Grid.Row="1" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,6,0,6">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding StatusText}" Opacity="0.75" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1"
                                                  IsOn="{Binding Enabled}"
                                                  Tag="{Binding Key}"
                                                  Toggled="Enabled_Toggled" />
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="8">
                                    <TextBlock Text="Mode" VerticalAlignment="Center" Opacity="0.75" />
                                    <ComboBox SelectedItem="{Binding Mode}"
                                              Tag="{Binding Key}"
                                              SelectionChanged="Mode_Changed"
                                              MinWidth="180">
                                        <ComboBoxItem Content="off" />
                                        <ComboBoxItem Content="ask" />
                                        <ComboBoxItem Content="auto_unless_risky" />
                                        <ComboBoxItem Content="full_auto" />
                                    </ComboBox>
                                    <TextBlock Grid.Column="2" Text="Scope" VerticalAlignment="Center" Opacity="0.75" />
                                    <ComboBox Grid.Column="3"
                                              SelectedItem="{Binding Scope}"
                                              Tag="{Binding Key}"
                                              SelectionChanged="Scope_Changed"
                                              MinWidth="180">
                                        <ComboBoxItem Content="workspace_only" />
                                        <ComboBoxItem Content="everything" />
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>

