<Page
    x:Class="Awarenet.ControlCenter.Pages.ChatsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid Padding="12" RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="*,Auto" Margin="4,4,4,8">
            <StackPanel>
                <TextBlock Text="Chats" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="ConnectionText" Text="Connecting..." Opacity="0.8" />
            </StackPanel>
            <Button x:Name="ReconnectButton" Grid.Column="1" Content="Reconnect" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="320,*" ColumnSpacing="12">
            <!-- ChatGPT-like sidebar -->
            <Grid RowDefinitions="Auto,*" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Orientation="Horizontal" Spacing="8" Padding="10">
                    <Button x:Name="NewChatButton" Content="New chat" />
                    <Button x:Name="RefreshChatsButton" Content="Refresh" />
                </StackPanel>
                <ListView x:Name="ChatList" Grid.Row="1" SelectionMode="Single" />
            </Grid>

            <!-- Main chat area -->
            <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto">
                <muxc:InfoBar x:Name="ErrorBar"
                              Grid.Row="0"
                              IsOpen="False"
                              Severity="Error"
                              Title="Error"
                              Message="-" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="MessagesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,6,0,6">
                                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            CornerRadius="12"
                                            Padding="12"
                                            HorizontalAlignment="{Binding Align}">
                                        <StackPanel Spacing="6" MaxWidth="840">
                                            <TextBlock Text="{Binding Role}" FontWeight="SemiBold" Opacity="0.8" />
                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Composer: voice + operator + attachments inside chat -->
                <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,*,Auto" ColumnSpacing="8" Margin="0,10,0,0">
                    <Button x:Name="MicButton" Content="Mic" />
                    <Button x:Name="VoiceCmdButton" Content="Voice Cmd" />
                    <Button x:Name="AttachButton" Content="Attach" />
                    <TextBox x:Name="InputBox"
                             Grid.Column="3"
                             PlaceholderText="Message…  (tip: /op &lt;goal&gt; to run operator)"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="44" />
                    <Button x:Name="SendButton" Grid.Column="4" Content="Send" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>

