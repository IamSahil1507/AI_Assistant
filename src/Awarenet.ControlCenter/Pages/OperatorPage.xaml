<Page
    x:Class="Awarenet.ControlCenter.Pages.OperatorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid Padding="16" RowDefinitions="Auto,*,Auto">
        <StackPanel Spacing="4">
            <TextBlock Text="Operator" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="Start a goal-driven operator task and watch step-by-step state." Opacity="0.8" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,12,0,12" RowDefinitions="Auto,Auto,*,Auto">
            <muxc:InfoBar x:Name="OpErrorBar"
                          Grid.Row="0"
                          IsOpen="False"
                          Severity="Error"
                          Title="Error"
                          Message="-" />

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="GoalBox" Width="700" PlaceholderText="Enter a goal (e.g., “open Gmail and draft an email…”)"/>
                <Button x:Name="StartButton" Content="Start" />
                <Button x:Name="RefreshButton" Content="Refresh" />
            </StackPanel>

            <ScrollViewer Grid.Row="2">
                <StackPanel Spacing="10">
                    <TextBlock Text="Active task" FontWeight="SemiBold" />
                    <TextBlock x:Name="ActiveSummary" Text="-" TextWrapping="Wrap" />
                    <TextBlock Text="Artifacts (recent)" FontWeight="SemiBold" Margin="0,8,0,0" />
                    <ListView x:Name="ArtifactsList" SelectionMode="Single" />
                    <TextBlock Text="History (recent)" FontWeight="SemiBold" Margin="0,8,0,0" />
                    <ListView x:Name="HistoryList" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="2" Margin="0,6,0,6">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" Opacity="0.85" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <TextBlock Grid.Row="2" Text="Next: live step timeline + artifacts + approvals inline." Opacity="0.7" />
    </Grid>
</Page>

