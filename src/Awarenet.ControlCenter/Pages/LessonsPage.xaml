<Page
    x:Class="Awarenet.ControlCenter.Pages.LessonsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid Padding="16" RowDefinitions="Auto,Auto,*">
        <StackPanel Spacing="4">
            <TextBlock Text="Lessons / Self‑Improve" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="View lessons learned and trigger troubleshoot/autofix (next)." Opacity="0.8" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,12,0,12">
            <Button x:Name="RefreshButton" Content="Refresh" />
            <TextBox x:Name="TailBox" Width="120" Text="50" />
        </StackPanel>

        <Grid Grid.Row="2" RowDefinitions="Auto,*">
            <muxc:InfoBar x:Name="ErrorBar"
                          Grid.Row="0"
                          IsOpen="False"
                          Severity="Error"
                          Title="Error"
                          Message="-" />
            <ListView x:Name="LessonsList" Grid.Row="1" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,6,0,6">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" Opacity="0.85" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>

