<Page
    x:Class="Awarenet.ControlCenter.Pages.DesktopAutomationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid Padding="16" RowDefinitions="Auto,Auto,*">
        <StackPanel Spacing="4">
            <TextBlock Text="Desktop Automation" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="List windows, launch apps, and take screenshots." Opacity="0.8" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,12,0,12">
            <Button x:Name="ListButton" Content="List windows" />
            <Button x:Name="ShotButton" Content="Screenshot full" />
            <TextBox x:Name="LaunchBox" Width="420" PlaceholderText="Launch command (e.g. notepad.exe)..." />
            <Button x:Name="LaunchButton" Content="Launch" />
        </StackPanel>

        <Grid Grid.Row="2" RowDefinitions="Auto,*" ColumnDefinitions="*,*"
              ColumnSpacing="12">
            <muxc:InfoBar x:Name="ErrorBar"
                          Grid.Row="0"
                          Grid.ColumnSpan="2"
                          IsOpen="False"
                          Severity="Error"
                          Title="Error"
                          Message="-" />

            <ListView x:Name="WindowsList" Grid.Row="1" Grid.Column="0" SelectionMode="Single" />
            <Image x:Name="PreviewImage" Grid.Row="1" Grid.Column="1" Stretch="Uniform" />
        </Grid>
    </Grid>
</Page>

