<Page
    x:Class="Awarenet.ControlCenter.Pages.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid Padding="16" RowDefinitions="Auto,Auto,*">
        <StackPanel Spacing="4">
            <TextBlock Text="Logs" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="View system/action/proactive logs and log files." Opacity="0.8" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,12,0,12">
            <ComboBox x:Name="LogKindBox" Width="220">
                <ComboBoxItem Content="system" IsSelected="True" />
                <ComboBoxItem Content="action" />
                <ComboBoxItem Content="proactive" />
                <ComboBoxItem Content="files" />
            </ComboBox>
            <Button x:Name="RefreshButton" Content="Refresh" />
            <TextBox x:Name="FileNameBox" Width="320" PlaceholderText="(files) enter log filename to view..." />
        </StackPanel>

        <Grid Grid.Row="2" RowDefinitions="Auto,*">
            <muxc:InfoBar x:Name="ErrorBar"
                          Grid.Row="0"
                          IsOpen="False"
                          Severity="Error"
                          Title="Error"
                          Message="-" />
            <TextBox x:Name="LogText"
                     Grid.Row="1"
                     FontFamily="Consolas"
                     IsReadOnly="True"
                     TextWrapping="NoWrap"
                     AcceptsReturn="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </Grid>
    </Grid>
</Page>

