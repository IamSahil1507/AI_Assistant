<Window
    x:Class="Awarenet.ControlCenter.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Title="Awarenet Control Center">

    <!-- Jarvis-style single-surface layout:
         - Left: vertical icon rail for modes
         - Center: main chat canvas
         - Right: contextual panel (operator steps, desktop windows, etc.)
         - Bottom: unified input bar with text / voice / operator / attachments -->

    <Grid Background="#0F1014">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="64" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Left rail: minimal icons, no ChatGPT-like list -->
        <StackPanel Grid.Column="0"
                    Grid.RowSpan="2"
                    Background="#14161C"
                    Spacing="12"
                    Padding="8,16,8,16">
            <TextBlock Text="AW"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center" />

            <StackPanel Spacing="4" Margin="0,24,0,0">
                <Button x:Name="ModeChatButton"
                        Background="#20232E"
                        Foreground="White"
                        Tag="chat"
                        ToolTipService.ToolTip="Chat"
                        Click="ModeButton_Click"
                        Width="40"
                        Height="40">
                    <SymbolIcon Symbol="Message" />
                </Button>
                <Button x:Name="ModeOperatorButton"
                        Background="#20232E"
                        Foreground="White"
                        Tag="operator"
                        ToolTipService.ToolTip="Operator"
                        Click="ModeButton_Click"
                        Width="40"
                        Height="40">
                    <SymbolIcon Symbol="Play" />
                </Button>
                <Button x:Name="ModeVoiceButton"
                        Background="#20232E"
                        Foreground="White"
                        Tag="voice"
                        ToolTipService.ToolTip="Voice Lab"
                        Click="ModeButton_Click"
                        Width="40"
                        Height="40">
                    <SymbolIcon Symbol="Microphone" />
                </Button>
                <Button x:Name="ModeDesktopButton"
                        Background="#20232E"
                        Foreground="White"
                        Tag="desktop"
                        ToolTipService.ToolTip="Desktop"
                        Click="ModeButton_Click"
                        Width="40"
                        Height="40">
                    <SymbolIcon Symbol="AllApps" />
                </Button>
                <Button x:Name="ModeBrowserButton"
                        Background="#20232E"
                        Foreground="White"
                        Tag="browser"
                        ToolTipService.ToolTip="Browser"
                        Click="ModeButton_Click"
                        Width="40"
                        Height="40">
                    <SymbolIcon Symbol="Globe" />
                </Button>
                <Button x:Name="ModeLogsButton"
                        Background="#20232E"
                        Foreground="White"
                        Tag="logs"
                        ToolTipService.ToolTip="Logs"
                        Click="ModeButton_Click"
                        Width="40"
                        Height="40">
                    <SymbolIcon Symbol="Document" />
                </Button>
            </StackPanel>
        </StackPanel>

        <!-- Center: main chat canvas -->
        <Grid Grid.Column="1" Grid.Row="0" Padding="16" RowDefinitions="Auto,*,Auto">
            <!-- Header: status + mini chat list trigger -->
            <Grid RowDefinitions="Auto" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Control Center"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="ConnectionStatusText"
                               Text="Connecting…"
                               Opacity="0.8"
                               FontSize="12" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button x:Name="ReconnectButton"
                            Content="Reconnect"
                            Click="ReconnectButton_Click" />
                    <Button x:Name="NewChatButton"
                            Content="New chat"
                            Click="NewChatButton_Click" />
                </StackPanel>
            </Grid>

            <!-- Chat timeline -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <!-- Narrow strip for recent chats (titles only) -->
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Recent chats list (non-ChatGPT style: compact cards) -->
                <Border Grid.Column="0"
                        Margin="0,0,12,0"
                        Background="#161820"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Sessions"
                                   Margin="12,10,12,4"
                                   FontSize="12"
                                   Opacity="0.8" />
                        <ListView x:Name="ChatList"
                                  SelectionMode="Single"
                                  BorderThickness="0"
                                  Margin="4,0,4,4"
                                  SelectionChanged="ChatList_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4"
                                            Padding="8"
                                            CornerRadius="6"
                                            Background="#20232E">
                                        <TextBlock Text="{Binding ChatId}"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontSize="12" />
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Messages -->
                <Grid Grid.Column="1" RowDefinitions="Auto,*">
                    <muxc:InfoBar x:Name="ErrorBar"
                                  Grid.Row="0"
                                  IsOpen="False"
                                  Severity="Error"
                                  Title="Error"
                                  Message="-" />

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="MessagesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6,0,6">
                                        <Border Background="#181B24"
                                                CornerRadius="12"
                                                Padding="12"
                                                HorizontalAlignment="{Binding Align}"
                                                MaxWidth="820">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Role}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Opacity="0.8" />
                                                <TextBlock Text="{Binding Content}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- Input bar -->
            <Grid Grid.Row="2"
                  Margin="0,10,0,0"
                  ColumnDefinitions="Auto,Auto,Auto,*,Auto"
                  ColumnSpacing="8">
                <Button x:Name="MicButton"
                        Content="Mic"
                        Click="MicButton_Click" />
                <Button x:Name="VoiceCmdButton"
                        Grid.Column="1"
                        Content="Voice Cmd"
                        Click="VoiceCmdButton_Click" />
                <Button x:Name="AttachButton"
                        Grid.Column="2"
                        Content="Attach"
                        Click="AttachButton_Click" />
                <TextBox x:Name="InputBox"
                         Grid.Column="3"
                         PlaceholderText="Message…  (tip: /op &lt;goal&gt; to run an operation)"
                         AcceptsReturn="True"
                         MinHeight="44"
                         TextWrapping="Wrap" />
                <Button x:Name="SendButton"
                        Grid.Column="4"
                        Content="Send"
                        Click="SendButton_Click" />
            </Grid>
        </Grid>

        <!-- Right contextual panel -->
        <Grid Grid.Column="2"
              Grid.RowSpan="2"
              Background="#10121A"
              Padding="12"
              RowDefinitions="Auto,*">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Context"
                           FontSize="14"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="ContextModeText"
                           Text="Chat"
                           Opacity="0.8"
                           FontSize="12" />
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <!-- For now, simple placeholder content that we wire up gradually -->
                <StackPanel x:Name="ContextPanelHost"
                            Spacing="8">
                    <TextBlock Text="This panel will show:"
                               Opacity="0.8"
                               FontSize="12" />
                    <TextBlock Text="- Operator steps &amp; approvals"
                               Opacity="0.8"
                               FontSize="12" />
                    <TextBlock Text="- Desktop windows &amp; screenshots"
                               Opacity="0.8"
                               FontSize="12" />
                    <TextBlock Text="- Browser sessions &amp; artifacts"
                               Opacity="0.8"
                               FontSize="12" />
                    <TextBlock Text="- Logs / lessons snippets"
                               Opacity="0.8"
                               FontSize="12" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>

