{
  "name": "awarenet-operator-bridge",
  "displayName": "Awarenet Operator Bridge",
  "description": "Local bridge that exposes VS Code/Cursor actions to Awarenet operator.",
  "version": "0.0.1",
  "publisher": "awarenet",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "awarenet.operatorBridge.start",
        "title": "Awarenet: Start Operator Bridge"
      },
      {
        "command": "awarenet.operatorBridge.stop",
        "title": "Awarenet: Stop Operator Bridge"
      }
    ],
    "configuration": {
      "title": "Awarenet Operator Bridge",
      "properties": {
        "awarenet.operatorBridge.port": {
          "type": "number",
          "default": 18999,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Local port for the operator bridge HTTP server."
        },
        "awarenet.operatorBridge.bindHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Bind host for the operator bridge HTTP server."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . -w",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.7.3",
    "@vscode/vsce": "^3.6.2"
  }
}
